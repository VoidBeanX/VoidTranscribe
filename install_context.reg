Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\*\shell\VoidTranscribe]
@="Transcribe with VoidTranscribe"
"Icon"="\"C:\\Program Files\\VoidTranscribe\\VoidTranscribe.exe\""

[HKEY_CLASSES_ROOT\*\shell\VoidTranscribe\command]
@="\"C:\\Program Files\\VoidTranscribe\\VoidTranscribe.exe\" \"%1\""
